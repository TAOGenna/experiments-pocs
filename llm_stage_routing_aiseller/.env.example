# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# =============================================================================
# LangSmith Tracing (optional - chatbot works without these)
# =============================================================================
# To enable tracing, uncomment these lines and add your LangSmith API key.
# Get your key at: https://smith.langchain.com/settings
#
# Once enabled, you'll see:
# - Each conversation turn as a trace
# - Router decisions and specialist LLM calls
# - Token usage per call
# - Latency breakdown by node
#
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=catalog-chatbot-poc
